# ---- 你的 API Key（GLM/MiniMax/DeepSeek 必填；Claude/Codex 走订阅 OAuth 不用 key）----
ZHIPU_API_KEY=          # GLM（智谱）
MINIMAX_API_KEY=        # MiniMax
DEEPSEEK_API_KEY=       # DeepSeek
# 下面两个仅在你想额外用「Claude/OpenAI 官方 API」兜底时才填（可留空）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- LiteLLM 网关 ----
LITELLM_MASTER_KEY=sk-change-me        # 上层访问网关用的 key
LITELLM_BASE_URL=http://litellm:4000

# ---- 数据库 ----
# LiteLLM 用量/计费库 + Agno session 库可共用一个 PG 实例
DATABASE_URL=postgresql+psycopg://agno:agno@postgres:5432/agno
LITELLM_DATABASE_URL=postgresql://agno:agno@postgres:5432/agno

# ---- CrewAI 子服务（可选）----
CREW_SERVICE_URL=http://crew-service:8001
