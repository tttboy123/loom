# 全局控制台（中枢）。纯标准库，无三方依赖。
FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends tzdata && rm -rf /var/lib/apt/lists/*
ENV PYTHONUNBUFFERED=1 PYTHONPATH=/app TZ=Asia/Shanghai
# 代码在 compose 里 bind-mount 进来（改了即时生效），这里只需运行时。
COPY console ./console
COPY devkit ./devkit
COPY app ./app
EXPOSE 8899
CMD ["python3", "-m", "console"]
