{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Incident",
  "type": "object",
  "required": ["kind", "metadata", "spec"],
  "properties": {
    "api_version": {
      "type": "string",
      "const": "loom.dev/v1"
    },
    "kind": {
      "type": "string",
      "const": "Incident"
    },
    "metadata": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["kind", "severity"],
      "properties": {
        "kind": { "type": "string" },
        "severity": { "type": "string" },
        "evidence_refs": { "type": "array" },
        "lineage": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
