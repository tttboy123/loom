{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolDescriptor",
  "description": "MCP-compatible tool descriptor — declares an invokable function and its JSON-Schema input contract.",
  "type": "object",
  "required": ["kind", "name", "description", "input_schema", "protocol_version"],
  "properties": {
    "kind": {
      "type": "string",
      "const": "ToolDescriptor"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.\\-]+$",
      "description": "Stable tool name (e.g. 'loom.dispatch_incident')."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable description of what the tool does."
    },
    "input_schema": {
      "type": "object",
      "description": "JSON Schema describing the tool's input arguments.",
      "properties": {
        "type": { "type": "string", "const": "object" },
        "properties": { "type": "object" },
        "required": { "type": "array", "items": { "type": "string" } },
        "additionalProperties": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "protocol_version": {
      "type": "string",
      "const": "loom.dev/v1"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}