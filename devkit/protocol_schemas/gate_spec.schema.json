{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GateSpec",
  "type": "object",
  "required": ["kind", "metadata", "spec"],
  "properties": {
    "api_version": {
      "type": "string",
      "const": "loom.dev/v1"
    },
    "kind": {
      "type": "string",
      "const": "GateSpec"
    },
    "metadata": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string" },
        "required_evidence": { "type": "array" },
        "verdict": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
