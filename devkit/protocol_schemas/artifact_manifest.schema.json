{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtifactManifest",
  "type": "object",
  "required": ["kind", "metadata", "spec"],
  "properties": {
    "api_version": {
      "type": "string",
      "const": "loom.dev/v1"
    },
    "kind": {
      "type": "string",
      "const": "ArtifactManifest"
    },
    "metadata": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "run_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["entries"],
      "properties": {
        "entries": { "type": "array" },
        "workspace_path": { "type": "string" },
        "candidate_path": { "type": "string" },
        "lineage": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
