{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidencePacket",
  "type": "object",
  "required": ["kind", "metadata", "spec"],
  "properties": {
    "api_version": {
      "type": "string",
      "const": "loom.dev/v1"
    },
    "kind": {
      "type": "string",
      "const": "EvidencePacket"
    },
    "metadata": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "work_item_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string" },
        "artifacts": { "type": "array" },
        "verify_commands": { "type": "array" },
        "lineage": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
